# ── 依赖 ──────────────────────────────────────────────
# 由 package-lock.json + `npm install` 复现，切勿提交（含 ~22MB 模型缓存）
node_modules/

# ── 构建产物 ──────────────────────────────────────────
# tsc 输出；clone 后用 `npm run build` 生成
dist/

# ── 记忆数据（若 MCP 从本目录启动会在此落盘）────────────
memory/

# ── 运行时 / 临时产物 ─────────────────────────────────
watcher-state.json
tsc_err.txt
db_schema.txt
*.log

# ── 环境与密钥 ────────────────────────────────────────
.env
.env.*
!.env.example

# ── 编辑器 / 操作系统 ─────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
